# Banco de dados — Neon (https://neon.tech)
# DATABASE_URL usa connection pooling (PgBouncer)
# DIRECT_URL é a conexão direta (necessária para migrations)
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# JWT — gere com: openssl rand -base64 32
JWT_SECRET="troque-por-um-segredo-forte"

# URL pública da API (sem barra no final)
NEXT_PUBLIC_API_URL="https://seu-projeto.vercel.app"

# Cron secret — protege o endpoint /api/cron/capi
CRON_SECRET="troque-por-um-segredo-forte"

# Opcional: código de teste do Meta Events Manager
# META_TEST_EVENT_CODE="TEST12345"

# WhatsApp Cloud API (Meta) — token de verificação do webhook CTWA
WHATSAPP_WEBHOOK_TOKEN="troque-por-um-segredo-forte"

# UazAPI — configurado por workspace via painel (não precisa de env global)
# As credenciais uazapiUrl e uazapiToken ficam salvas por workspace no banco
